<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/black">

    <!-- Top Navigation Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imageViewClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_close" />

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="New task"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Cancel"
            android:textColor="@color/brand_blue"
            android:textSize="18sp" />
    </RelativeLayout>

    <!-- Header Text -->
    <TextView
        android:id="@+id/textViewPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="What's on your mind?"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:textStyle="bold" />

    <!-- Input Field (originally a TextView acting as input?) -->
    <EditText
        android:id="@+id/editTextTaskTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@android:color/transparent"
        android:hint="Enter task title..."
        android:textColor="@android:color/white"
        android:textColorHint="@color/text_gray"
        android:textSize="22sp" />

    <!-- Space filler -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Options Buttons -->
    <Button
        android:id="@+id/buttonAttachImage"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/text_gray"
        android:drawableStart="@drawable/ic_image"
        android:paddingStart="24dp"
        android:text="@string/attach_image"
        android:textAlignment="viewStart"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/buttonRecordAudio"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/text_gray"
        android:drawableStart="@drawable/outline_mic_24"
        android:paddingStart="24dp"
        android:text="@string/record_audio"
        android:textAlignment="viewStart"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/buttonSetDeadline"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/text_gray"
        android:drawableStart="@drawable/ic_calander"
        android:paddingStart="24dp"
        android:text="@string/set_deadline"
        android:textAlignment="viewStart"
        android:textAllCaps="false" />

    <!-- Save Button -->
    <Button
        android:id="@+id/buttonSaveTask"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/brand_blue"
        android:text="Save text"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textAllCaps="false" />

</LinearLayout>